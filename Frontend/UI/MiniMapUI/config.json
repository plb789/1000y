{
  "name": "MiniMapUI",
  "version": "1.0",
  "description": "小地图界面配置",
  "components": {
    "miniMap": {
      "enabled": true,
      "position": { "x": "auto", "y": 60, "right": 20 },
      "size": { "width": 150, "height": 150 },
      "style": {
        "background": "rgba(0, 0, 0, 0.6)",
        "border": "2px solid #444",
        "borderRadius": "50%"
      },
      "showPlayer": true,
      "showNPCs": true,
      "showMonsters": true,
      "showOtherPlayers": true,
      "showPortal": true,
      "rotation": "fixed"
    },
    "playerIcon": {
      "shape": "triangle",
      "color": "#4ade80",
      "size": 8
    },
    "npcIcon": {
      "shape": "circle",
      "color": "#fbbf24",
      "size": 6
    },
    "monsterIcon": {
      "shape": "circle",
      "color": "#ef4444",
      "size": 5
    },
    "playerIcon": {
      "shape": "circle",
      "color": "#60a5fa",
      "size": 5
    },
    "portalIcon": {
      "shape": "square",
      "color": "#a855f7",
      "size": 6
    },
    "mapName": {
      "enabled": true,
      "position": { "x": "auto", "y": "auto", "right": 20, "below": 10 },
      "style": {
        "color": "#fff",
        "fontSize": 12,
        "textShadow": "1px 1px 2px rgba(0,0,0,0.8)"
      }
    }
  }
}
