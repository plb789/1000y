{
  "name": "RoleUI",
  "version": "1.0",
  "description": "角色信息界面配置",
  "components": {
    "rolePanel": {
      "enabled": true,
      "position": { "x": 20, "y": 60 },
      "size": { "width": 220, "height": "auto" },
      "style": {
        "background": "rgba(0, 0, 0, 0.8)",
        "border": "2px solid #e94560",
        "borderRadius": 10,
        "padding": 15
      },
      "attributes": {
        "hp": { "label": "生命", "color": "#ef4444", "icon": "❤️" },
        "mp": { "label": "内力", "color": "#60a5fa", "icon": "💧" },
        "attack": { "label": "攻击", "color": "#4ade80", "icon": "⚔️" },
        "defense": { "label": "防御", "color": "#4ade80", "icon": "🛡️" },
        "speed": { "label": "速度", "color": "#fbbf24", "icon": "💨" },
        "hit": { "label": "命中", "color": "#60a5fa", "icon": "🎯" },
        "dodge": { "label": "闪避", "color": "#60a5fa", "icon": "💨" },
        "crit": { "label": "暴击", "color": "#f472b6", "icon": "💥" }
      },
      "displayMode": "compact"
    },
    "topBar": {
      "enabled": true,
      "position": { "x": 0, "y": 0 },
      "size": { "width": "100%", "height": 50 },
      "style": {
        "background": "linear-gradient(180deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0))"
      },
      "elements": ["name", "level", "gold", "hp", "mp", "onlineCount", "fps"]
    },
    "nameplate": {
      "enabled": true,
      "showHP": true,
      "showName": true,
      "showLevel": true,
      "style": {
        "fontSize": 12,
        "nameColor": "#ffffff",
        "hpBarHeight": 4
      }
    }
  }
}
