{
  "name": "SkillBarUI",
  "version": "1.0",
  "description": "技能栏界面配置",
  "components": {
    "skillBar": {
      "enabled": true,
      "position": { "x": "center", "y": "auto", "bottom": 0 },
      "size": { "height": 80 },
      "style": {
        "background": "linear-gradient(0deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0))",
        "paddingBottom": 10
      },
      "slots": {
        "count": 8,
        "size": { "width": 56, "height": 56 },
        "gap": 8,
        "borderRadius": 8,
        "shortcutKeys": ["1", "2", "3", "4", "5", "6", "7", "8", "0"]
      },
      "cooldown": {
        "showProgress": true,
        "showText": true,
        "overlayColor": "rgba(0, 0, 0, 0.6)"
      }
    },
    "skillSlot": {
      "normal": {
        "background": "linear-gradient(135deg, rgba(45, 55, 72, 0.9), rgba(26, 32, 44, 0.9))",
        "border": "2px solid #4a5568"
      },
      "hover": {
        "borderColor": "#e94560",
        "transform": "translateY(-5px)",
        "boxShadow": "0 5px 15px rgba(233, 69, 96, 0.3)"
      },
      "cooldown": {
        "opacity": 0.5,
        "borderColor": "#e94560"
      },
      "empty": {
        "background": "rgba(45, 55, 72, 0.3)",
        "border": "2px dashed #4a5568"
      }
    },
    "inventoryBtn": {
      "enabled": true,
      "position": "first",
      "style": {
        "background": "linear-gradient(135deg, #8b5cf6, #7c3aed)",
        "icon": "📦"
      }
    }
  }
}
